{
  "name": "r2-registry",
  "version": "1.1.0",
  "description": "An open-source R2 registry",
  "main": "index.ts",
  "scripts": {
    "deploy": "bun x -p wrangler@latest wrangler deploy --minify --env production",
    "dev:miniflare": "cross-env NODE_ENV=development bun x -p wrangler@latest wrangler --env dev dev --port 9999 --live-reload",
    "typecheck": "bun x tsc",
    "test": "vitest --config test/vitest.config.mts run"
  },
  "dependencies": {
    "@cfworker/base64url": "^1.12.5",
    "@tsndr/cloudflare-worker-jwt": "^3.2.1",
    "itty-router": "^5.0.23",
    "zod": "^4.3.5"
  },
  "optionalDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260118.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "miniflare": "4.20260317.3",
    "prettier": "3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "",
  "license": "Apache-2.0",
  "pnpm": {
    "overrides": {
      "@types/node": "18.15.3"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}
